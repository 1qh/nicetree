{
  "name": "idecn",
  "version": "0.0.3",
  "private": false,
  "description": "IDE-like workspace and file tree components for React with material icons",
  "keywords": [
    "react",
    "file-tree",
    "workspace",
    "material-icons",
    "shadcn",
    "ide"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1qh/idecn.git"
  },
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": "./src/idecn.tsx"
  },
  "main": "./src/idecn.tsx",
  "types": "./src/idecn.tsx",
  "files": [
    "src/idecn.tsx",
    "src/monokai-lite.ts",
    "src/_generated"
  ],
  "workspaces": [
    "web"
  ],
  "scripts": {
    "build": "bun run gen && cd web && bun run build",
    "check": "lintmax check",
    "ci": "bun i && bun run gen && bun run check && bun run build && bun run test:registry",
    "clean": "rm -rf node_modules bun.lock src/_generated web/public/r .cache .next .turbo web/node_modules web/.next test-results",
    "dev": "cd web && bun run dev",
    "fix": "lintmax fix && bun run build",
    "gen": "bun scripts/gen-icons.ts && bun scripts/gen-demo-tree.ts && bun scripts/build-registry.ts",
    "prepublishOnly": "bun run gen",
    "publish:git": "bash scripts/publish.sh",
    "screenshot": "cd web && bun ../scripts/screenshot.ts",
    "test": "bun run check && bun run build && bun run test:registry",
    "test:registry": "bash scripts/test-registry.sh"
  },
  "dependencies": {
    "@base-ui/react": "latest",
    "@monaco-editor/react": "latest",
    "@shikijs/monaco": "latest",
    "clsx": "latest",
    "dockview-core": "latest",
    "dockview-react": "latest",
    "lucide-react": "latest",
    "react-resizable-panels": "latest",
    "shiki": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@types/react": "latest",
    "bun-types": "latest",
    "lintmax": "latest",
    "material-icon-theme": "latest",
    "next": "latest",
    "next-themes": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "lintmax"
  ]
}
