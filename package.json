{
  "name": "idecn",
  "version": "0.0.1",
  "private": false,
  "description": "IDE-like UI components for React with material-icon-theme icons",
  "keywords": [
    "react",
    "file-tree",
    "ide",
    "material-icons",
    "shadcn",
    "dockview"
  ],
  "repository": "1qh/idecn",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "src"
  ],
  "scripts": {
    "build": "bun x tsc --noEmit && bun scripts/gen-demo-tree.ts && cd web && bun run build",
    "check": "lintmax check",
    "clean": "rm -rf node_modules bun.lock dist .cache .next .turbo web/node_modules web/.next",
    "dev": "cd web && bun run dev",
    "fix": "lintmax fix && bun run build",
    "gen": "bun scripts/gen-icons.ts && bun scripts/gen-demo-tree.ts && bun scripts/build-registry.ts"
  },
  "dependencies": {
    "@base-ui/react": "latest",
    "clsx": "latest",
    "tailwind-merge": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "bun-types": "^1.3.11",
    "lintmax": "latest",
    "material-icon-theme": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "typescript": "latest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
