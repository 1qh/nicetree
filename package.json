{
  "name": "idecn",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*",
    "readonly/*"
  ],
  "scripts": {
    "action": "sh up.sh",
    "build": "turbo build --output-logs=errors-only",
    "check": "lintmax check",
    "clean": "sh clean.sh",
    "fix": "lintmax fix",
    "postinstall": "sherif",
    "prepare": "bunx simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "sh up.sh && git add -u"
  },
  "devDependencies": {
    "@playwright/test": "latest",
    "@tailwindcss/postcss": "latest",
    "@tailwindcss/typography": "latest",
    "@turbo/gen": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "^9.39.2",
    "lintmax": "latest",
    "material-icon-theme": "latest",
    "sherif": "latest",
    "simple-git-hooks": "latest",
    "tailwindcss": "latest",
    "tsdown": "latest",
    "turbo": "latest",
    "typescript": "latest"
  },
  "packageManager": "bun@1.3.11",
  "trustedDependencies": [
    "esbuild",
    "lintmax",
    "simple-git-hooks"
  ]
}
