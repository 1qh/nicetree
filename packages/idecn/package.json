{
  "name": "idecn",
  "version": "0.0.8",
  "private": false,
  "description": "IDE-like workspace and file tree components for React with material icons",
  "keywords": [
    "react",
    "file-tree",
    "workspace",
    "material-icons",
    "shadcn",
    "ide"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/1qh/idecn.git"
  },
  "license": "MIT",
  "author": "",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/idecn.d.mts",
      "import": "./dist/idecn.mjs"
    }
  },
  "main": "./dist/idecn.mjs",
  "types": "./dist/idecn.d.mts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "gen": "bun scripts/gen-icons.ts && bun scripts/build-registry.ts",
    "prepublishOnly": "bun run build",
    "postpublish": "bunx pm4ai@latest cleanup",
    "test:registry": "bash scripts/test-registry.sh"
  },
  "dependencies": {
    "@a/ui": "workspace:*",
    "@icons-pack/react-simple-icons": "latest",
    "@monaco-editor/react": "latest",
    "@shikijs/monaco": "latest",
    "@tanstack/react-hotkeys": "latest",
    "dockview-core": "latest",
    "dockview-react": "latest",
    "jotai": "latest"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  }
}
